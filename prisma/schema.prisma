generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  role     Role   @default(USER)
}

model Stuff {
  id        Int       @id @default(autoincrement())
  name      String
  quantity  Int
  condition Condition @default(good)
  owner     String
}

model Entry {
  id        Int      @id @default(autoincrement())
  location  Location @default(Keller)
  busyLevel Int      @default(0)
  comment   String   @default("")
}

enum Role {
  USER
  ADMIN
}

enum Condition {
  excellent
  good
  fair
  poor
}

enum Location {
  Keller
  Art
  Kuykendall
  Bilger
  CampusCenter
  Moore
  ParadisePalms
  POST
}
