generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  role     Role   @default(USER)
}

model Stuff {
  id        Int       @id @default(autoincrement())
  name      String
  quantity  Int
  condition Condition @default(good)
  owner     String
}

model Entry {
  id        Int           @id @default(autoincrement())
  busyLevel Int           @default(0)
  comment   String        @default("")
  location EntryLocation  @default(HamiltonLibrary)
}

enum Role {
  USER
  ADMIN
}

enum Condition {
  excellent
  good
  fair
  poor
}

enum EntryLocation {
  HamiltonLibrary
  WarriorRecreationCenter
  CampusCenterFoodCourt
  CampusCenterOutdoorCourt
  TacoBellFoodCourt
  ParadisePalms
  POST2ndFloor
}
