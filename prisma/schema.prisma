// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  role     Role   @default(USER)
}

enum Condition {
  excellent
  good
  fair
  poor
}

model Stuff {
  id        Int       @id @default(autoincrement())
  name      String
  quantity  Int
  condition Condition @default(good)
  owner     String
}

enum Location {
  Keller
  Art
  Kuykendall
  Bilger
  CampusCenter
  Moore
  ParadisePalms
  POST
}

model Entry {
  id        Int       @id @default(autoincrement())
  location  Location  @default(Keller)
  busyLevel Int       @default(0)
  comment   String    @default("")
}
